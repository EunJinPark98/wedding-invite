# Supabase 설정 (없으면 로컬 .data/invitations.json 파일에 저장됩니다 - 개발용)
# https://supabase.com 에서 프로젝트 생성 후 Settings > API 에서 값 복사

NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key

# 서버에서만 사용 (RLS 우회). 네이버 로그인에 필수, 저장 시에도 우선 사용됩니다.
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# 네이버 로그인 (https://developers.naver.com 애플리케이션 등록 후 발급)
# Callback URL: {사이트주소}/api/auth/naver/callback
NAVER_CLIENT_ID=your-naver-client-id
NAVER_CLIENT_SECRET=your-naver-client-secret

# 카카오 로그인은 Supabase 대시보드에서 설정: Authentication > Providers > Kakao
# (https://developers.kakao.com 앱 생성 → REST API 키/Secret 입력)
